#include <stdio.h>
#include <stdlib.h>
#include <string.h>

typedef struct {
    char ch;
    int freq;
} CharFreq;

int compare(const void *a, const void *b) {
    return ((CharFreq *)b)->freq - ((CharFreq *)a)->freq;
}

char* frequencySort(char* s) {
    int len = strlen(s);
    
  
    CharFreq *counts = (CharFreq *)calloc(128, sizeof(CharFreq));
    
    
    for (int i = 0; i < 128; i++) {
        counts[i].ch = (char)i;
        counts[i].freq = 0;
    }
    
 
    for (int i = 0; i < len; i++) {
        counts[(unsigned char)s[i]].freq++;
    }
    
   
    qsort(counts, 128, sizeof(CharFreq), compare);
    

    char *result = (char *)malloc((len + 1) * sizeof(char));
    int index = 0;
    
    for (int i = 0; i < 128; i++) {
       
        if (counts[i].freq == 0) {
            break;
        }
        
      
        for (int j = 0; j < counts[i].freq; j++) {
            result[index++] = counts[i].ch;
        }
    }
    
    result[index] = '\0'; 
    

    free(counts);
    
    return result;
}
