#include <string.h>
#include <stdlib.h>

char * longestPalindrome(char * s)
{
    int n = strlen(s);

    if(n == 0)
        return "";

    int start = 0;
    int maxLen = 1;

    int i;

    for(i = 0; i < n; i++)
    {
        // Odd length palindrome
        int left = i;
        int right = i;

        while(left >= 0 && right < n && s[left] == s[right])
        {
            if(right - left + 1 > maxLen)
            {
                start = left;
                maxLen = right - left + 1;
            }

            left--;
            right++;
        }

        // Even length palindrome
        left = i;
        right = i + 1;

        while(left >= 0 && right < n && s[left] == s[right])
        {
            if(right - left + 1 > maxLen)
            {
                start = left;
                maxLen = right - left + 1;
            }

            left--;
            right++;
        }
    }

    char *ans = (char *)malloc((maxLen + 1) * sizeof(char));

    for(i = 0; i < maxLen; i++)
    {
        ans[i] = s[start + i];
    }

    ans[maxLen] = '\0';

    return ans;
}
