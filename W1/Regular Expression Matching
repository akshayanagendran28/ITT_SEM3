#include <stdbool.h>
#include <string.h>

bool isMatch(char *s, char *p)
{
    int m = strlen(s);
    int n = strlen(p);

    bool dp[m + 1][n + 1];

    int i, j;

    for(i = 0; i <= m; i++)
    {
        for(j = 0; j <= n; j++)
        {
            dp[i][j] = false;
        }
    }

    dp[0][0] = true;

    for(j = 2; j <= n; j++)
    {
        if(p[j - 1] == '*')
        {
            dp[0][j] = dp[0][j - 2];
        }
    }

    for(i = 1; i <= m; i++)
    {
        for(j = 1; j <= n; j++)
        {
            if(p[j - 1] == '.' || p[j - 1] == s[i - 1])
            {
                dp[i][j] = dp[i - 1][j - 1];
            }
            else if(p[j - 1] == '*')
            {
                dp[i][j] = dp[i][j - 2];

                if(p[j - 2] == '.' || p[j - 2] == s[i - 1])
                {
                    if(dp[i - 1][j])
                    {
                        dp[i][j] = true;
                    }
                }
            }
        }
    }

    return dp[m][n];
}
